{
  "extends": ["@tsconfig/node22/tsconfig", "@tsconfig/strictest/tsconfig"],
  "compilerOptions": {
    "declaration": false,
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "outDir": "dist/src",
    "target": "esnext",
    "types": ["@types/babel__core", "@types/node"],
    "verbatimModuleSyntax": true
  },
  "include": ["src", "types"],
  "exclude": []
}
